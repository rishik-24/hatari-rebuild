{
  "expo": {
    "name": "expo-rn-starter-template",
    "slug": "expo-rn-starter-template",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icons/ios-tinted.png",
    "scheme": "expornstartertemplate",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/icons/ios-tinted.png",
      "resizeMode": "cover"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icons/splash-icon-dark.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": ["expo-router", "expo-font"],
    "experiments": {
      "typedRoutes": true
    },
    "owner": "Rishik Roy"
  }
}
